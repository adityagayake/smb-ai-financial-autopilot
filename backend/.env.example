# Copy to `.env` in this folder (`backend/.env`) and fill in secrets.
# Loaded automatically on startup via python-dotenv (see `main.py`).

# --- Database: PostgreSQL + Prisma (required) ---
# Start DB: docker compose -f docker-compose.yml up -d
#
# Apply schema to THIS database (no global `prisma` needed – uses venv):
#   ./scripts/sync-prisma-db.sh
# Or manually (put venv on PATH so `prisma-client-py` is found during generate):
#   export PATH="$(pwd)/.venv/bin:$PATH"
#   ./.venv/bin/prisma db push --schema prisma/schema.prisma
#   ./.venv/bin/prisma generate --schema prisma/schema.prisma
#
# Prisma Studio must use the same DATABASE_URL and schema file:
#   ./.venv/bin/prisma studio --schema prisma/schema.prisma
DATABASE_URL=postgresql://smb:smb@localhost:5432/smb_ai

# --- JWT auth ---
# JWT_SECRET_KEY=02277a43b45bfb8dbac579a35efb3d96e60949ad8612049373fafd4562f40f6b
# JWT_EXPIRE_MINUTES=10080

# --- Razorpay payment links (live links when both are set) ---
# RAZORPAY_KEY_ID=rzp_test_SYZb1s6uhoduP6
# RAZORPAY_KEY_SECRET=RjZHhey60Yr1kCDKBlBKBaAO
# Webhook secret from Razorpay Dashboard → Webhooks → signing secret (HMAC-SHA256 of raw body).
# POST /webhooks/razorpay – if unset, signature verification is skipped (dev only).
# RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# --- Daily WhatsApp morning brief (8 AM IST) – APScheduler; requires Meta WhatsApp + user whatsapp_number ---
# BRIEFING_ENABLED=true
# When false, the cron job is not registered.

# --- Background system engine (financial loop) ---
# SYSTEM_ENGINE_INTERVAL_SEC=5
# SYSTEM_ENGINE_INITIAL_BALANCE=10000
# SYSTEM_ENGINE_HORIZON_DAYS=30
# SYSTEM_ENGINE_MONTE_CARLO_PATHS=500
# SYSTEM_ENGINE_DISABLED=false

# --- WhatsApp – Meta Cloud API (https://developers.facebook.com/docs/whatsapp/cloud-api) ---
# 1) Create a Meta app → WhatsApp → get a temporary access token, Phone number ID, and Business ID.
# 2) Add your own number as a recipient (sandbox) or go live after business verification.
# 3) Paste below; restart the API. POST /execute/whatsapp will then call Graph instead of simulating.
#
# Required for live sends:
# WHATSAPP_PHONE_NUMBER_ID=          # e.g. 123456789012345 (from WhatsApp > API Setup)
# WHATSAPP_ACCESS_TOKEN=             # long-lived System User token recommended for production
#
# Optional:
# WHATSAPP_GRAPH_API_VERSION=v21.0   # Graph API version segment in the URL
# WHATSAPP_DEFAULT_COUNTRY_CODE=91     # if you pass 10-digit Indian numbers without country code
# WHATSAPP_BUSINESS_ACCOUNT_ID=        # for dashboards / webhooks only; not required for outbound text

# --- Optional integrations ---
# Redis: shared engine snapshot for multi-worker / HA (see `services/redis_snapshot.py`, `state/global_state.py`).
# docker compose up -d redis  →  redis://localhost:6379/0
# REDIS_URL=redis://localhost:6379/0
# REDIS_SNAPSHOT_ENABLED=true
# REDIS_SNAPSHOT_KEY=smb:engine_snapshot:v1
# REDIS_SNAPSHOT_TTL_SEC=120
#
# Growth / ops (subscription tier override for demos; disable in production billing).
# GROWTH_ALLOW_TIER_OVERRIDE=true
#
# COLLECTION_LADDER_ENABLED=true
# BENCHMARK_CRON_ENABLED=true
#
# --- OCR (images + scanned PDFs) ---
# Code loads `pymupdf` from requirements.txt to rasterize scanned PDF pages; no extra system lib.
#
# Use at least one of these for OCR (Vision preferred for accuracy):
# GOOGLE_APPLICATION_CREDENTIALS=./ocr_key.json
# GOOGLE_VISION_API_KEY=your_cloud_vision_rest_api_key
#
# Local fallback – install Tesseract (macOS: brew install tesseract). The API prepends
# /opt/homebrew/bin on startup and resolves the tesseract binary for pytesseract; override if needed:
# TESSERACT_CMD=/opt/homebrew/bin/tesseract
#
# Scanned PDF tuning (optional; defaults match ocr_service.py):
# OCR_PDF_MAX_PAGES=10
# OCR_PDF_RENDER_ZOOM=2.0

# --- Twilio Voice (Hindi outbound calls from POST /execute/twilio-call) ---
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1xxxxxxxxxx   # your Twilio number, E.164
#
# Meta WhatsApp webhook verification (GET /webhooks/whatsapp):
# WHATSAPP_VERIFY_TOKEN=            # same string as in Meta dashboard
# Public web app URL (signup link when WhatsApp number is not registered; AA callback redirect):
# PUBLIC_APP_URL=https://your-domain.com
# Base URL of this API as seen by browsers (Setu redirects to PUBLIC_API_URL/aa/callback):
# PUBLIC_API_URL=https://api.your-domain.com

# --- Account Aggregator (Setu AA) – POST /aa/initiate, GET /aa/callback, GET /aa/status ---
# When unset, consent + FI use mock data for local testing.
# SETU_AA_BASE_URL=https://sandbox.setu.co
# SETU_AA_CLIENT_ID=
# SETU_AA_CLIENT_SECRET=
# Optional paths if your tenant differs:
# SETU_AA_CONSENT_PATH=/v2/consents
# SETU_AA_FI_PATH=/v2/consents/{consent_id}/fi
# Or use a static Bearer instead of client id/secret:
# SETU_AA_ACCESS_TOKEN=
# Custom header format "Name: value" (overrides Bearer above):
# SETU_AA_AUTH_HEADER=
# Nightly cron to refresh FI for ACTIVE consents (also needs BRIEFING-style scheduler path):
# AA_REFRESH_ENABLED=true

# --- GST (GSTIN on BusinessProfile; optional future GSP live sync) ---
# GST_GSP_ENABLED=false

# --- Multilingual assistant (Hindi / Hinglish / regional via translation + gTTS) ---
# Uses Google Translate (deep-translator, no key) for EN ↔ hi,ta,te,…
# Optional: OpenAI for Whisper (uploaded audio) and friendly Hinglish polish:
# OPENAI_API_KEY=sk-...   # never commit real keys; set in backend/.env only
# OPENAI_WHISPER_MODEL=whisper-1
# OPENAI_TONE_MODEL=gpt-4o-mini
# OPENAI_KHATA_MODEL=gpt-4o-mini   # handwritten khata photo → suggested sale lines (vision)

# --- RL (tabular Q-learning for action ordering + module clicks) ---
# RL_LEARNING_RATE=0.35
# RL_DISCOUNT=0.9
# RL_EPSILON=0.12
# RL_SEED_BOOTSTRAP=1
# Persists to backend/data/rl_qtable.json (gitignored)
